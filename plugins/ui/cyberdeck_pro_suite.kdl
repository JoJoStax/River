plugin id="cyberdeck-pro-suite" name="Cyberdeck Pro" mode="hotplug" {
    style {
        palette accent="#00f0ff" secondary="#ff0055" text="#ffffff" border="#00f0ff" background="#050811"
        typography family="monospace" header-size=22.0 body-size=13.0
        spacing item-x=8.0 item-y=8.0 padding=12.0
        background-type "matrix"
        fill "#00ff66"
        secondary "#002211"
    }
    layout target="desktop" {
        top-panel id="telemetry" height=48.0 fill="#0a0f24ff" {
            column spacing=6.0 padding=8.0 {
                row align="center" spacing=16.0 {
                    image url="https://raw.githubusercontent.com/egui/egui/master/crates/egui/assets/ferris.svg" width=32.0 height=32.0 rounding=4.0
                    heading text="Matrix" color="accent" size=18.0
                    spacer
                    label text="Connected" color="secondary"
                }
                row align="center" spacing=10.0 {
                    device-switcher style="horizontal"
                    theme-switcher style="horizontal"
                }
            }
        }
        left-panel id="security-nav" width=200.0 fill="#070b1aff" {
            column spacing=10.0 padding=12.0 {
                heading text="Channels" size=15.0 color="accent"
                separator
                menu-bar id="category-nav" style="pills"
                spacer
                button label="Overclock" color="accent"
            }
        }
        right-panel id="diagnostics" width=180.0 fill="#070b1aff" {
            column spacing=10.0 padding=12.0 {
                heading text="Shards" size=15.0 color="secondary"
                separator
                button label="Encrypt" color="secondary"
                button label="Purge" color="text"
            }
        }
        bottom-panel id="status-footer" height=28.0 fill="#0a0f24ff" {
            row align="center" spacing=12.0 {
                label text="Stream Active" color="accent" size=11.0
                spacer
            }
        }
        central-panel id="matrix-core" fill="#05081190" {
            column spacing=12.0 padding=14.0 {
                catalog-view style="terminal_feed" columns=2 rounding=4.0 border-width=1.0 {
                    animation effect="none" speed=1.0
                }
            }
        }
    }
    layout target="mobile" {
        top-panel id="mobile-header" height=60.0 fill="#0a0f24ff" {
            column spacing=6.0 padding=8.0 {
                row align="center" spacing=12.0 {
                    heading text="HUD" color="accent" size=18.0
                    spacer
                }
                row align="center" spacing=8.0 {
                    device-switcher style="compact"
                    theme-switcher style="horizontal"
                }
            }
        }
        bottom-panel id="mobile-nav" height=54.0 fill="#070b1aff" {
            row align="center" spacing=8.0 {
                menu-bar id="category-nav" style="pills"
            }
        }
        central-panel id="mobile-feed" fill="#050811ff" {
            column spacing=10.0 padding=10.0 {
                catalog-view style="terminal_feed" columns=1 rounding=8.0 border-width=1.0 {
                    animation effect="none" speed=1.0
                }
            }
        }
    }
    layout target="tv" {
        top-panel id="tv-header" height=80.0 fill="#0a0f24ff" {
            column spacing=10.0 padding=14.0 {
                row align="center" spacing=20.0 {
                    heading text="Cinema" color="accent" size=26.0
                    spacer
                }
                row align="center" spacing=14.0 {
                    device-switcher style="horizontal"
                    theme-switcher style="horizontal"
                }
            }
        }
        bottom-panel id="tv-footer" height=50.0 fill="#0a0f24ff" {
            row align="center" spacing=20.0 {
                label text="Navigate   Launch   Return" color="accent" size=16.0
                spacer
                menu-bar id="category-nav" style="pills"
            }
        }
        central-panel id="tv-grid" fill="#050811ff" {
            column spacing=24.0 padding=28.0 {
                catalog-view style="live_tiles" columns=4 rounding=16.0 border-width=2.0 {
                    animation effect="none" speed=1.0
                }
            }
        }
    }
}
