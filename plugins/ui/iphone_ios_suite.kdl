plugin id="iphone-ios-suite" name="Apple iOS & macOS" mode="core" {
    style {
        palette accent="#0a84ff" secondary="#ff375f" text="#ffffff" border="#2c2c2e" background="#000000"
        typography family="proportional" header-size=24.0 body-size=14.0
        spacing item-x=12.0 item-y=12.0 padding=16.0
        background-type "stars"
        fill "#000000"
        secondary "#ffffff"
        speed 0.5
    }
    layout target="desktop" {
        top-panel id="cuper-header" height=48.0 fill="#1c1c1eff" {
            column spacing=6.0 padding=8.0 {
                row align="center" spacing=16.0 {
                    image url="https://raw.githubusercontent.com/egui/egui/master/crates/egui/assets/ferris.svg" width=32.0 height=32.0 rounding=8.0
                    heading text="Music" color="text" size=18.0
                    spacer
                }
                row align="center" spacing=10.0 {
                    device-switcher style="horizontal"
                    theme-switcher style="horizontal"
                }
            }
        }
        left-panel id="cuper-sidebar" width=200.0 fill="#121214ff" {
            column spacing=12.0 padding=14.0 {
                heading text="Library" size=14.0 color="accent"
                separator
                menu-bar id="category-nav" style="pills"
            }
        }
        bottom-panel id="cuper-dock" height=36.0 fill="#1c1c1eff" {
            row align="center" spacing=16.0 {
                label text="Music   TV   Podcasts" color="accent" size=13.0
                spacer
                label text="4:20 PM" color="secondary" size=13.0
            }
        }
        central-panel id="cuper-content" fill="#00000080" {
            column spacing=16.0 padding=20.0 {
                catalog-view style="floating_cards" columns=3 rounding=20.0 border-width=1.0 {
                    animation effect="none" speed=1.0
                }
            }
        }
    }
    layout target="mobile" {
        top-panel id="ios-header" height=60.0 fill="#1c1c1eff" {
            column spacing=8.0 padding=10.0 {
                row align="center" spacing=14.0 {
                    heading text="Library" color="text" size=24.0
                    spacer
                }
                row align="center" spacing=8.0 {
                    device-switcher style="compact"
                    theme-switcher style="horizontal"
                }
            }
        }
        bottom-panel id="ios-tabbar" height=56.0 fill="#1c1c1eff" {
            row align="center" spacing=10.0 {
                menu-bar id="category-nav" style="pills"
            }
        }
        central-panel id="ios-feed" fill="#000000ff" {
            column spacing=14.0 padding=14.0 {
                catalog-view style="floating_cards" columns=1 rounding=24.0 border-width=1.0 {
                    animation effect="none" speed=1.0
                }
            }
        }
    }
    layout target="tv" {
        top-panel id="tvos-header" height=80.0 fill="#1c1c1eff" {
            column spacing=10.0 padding=14.0 {
                row align="center" spacing=20.0 {
                    heading text="Apple TV" color="text" size=26.0
                    spacer
                }
                row align="center" spacing=14.0 {
                    device-switcher style="horizontal"
                    theme-switcher style="horizontal"
                }
            }
        }
        bottom-panel id="tvos-footer" height=50.0 fill="#1c1c1eff" {
            row align="center" spacing=20.0 {
                label text="Touchpad   Select   Menu" color="accent" size=16.0
                spacer
                menu-bar id="category-nav" style="pills"
            }
        }
        central-panel id="tvos-plaza" fill="#000000ff" {
            column spacing=24.0 padding=28.0 {
                catalog-view style="floating_cards" columns=4 rounding=24.0 border-width=2.0 {
                    animation effect="none" speed=1.0
                }
            }
        }
    }
}
