plugin id="one-ui-suite" name="Samsung One UI" mode="hotplug" {
    style {
        palette accent="#007aff" secondary="#00d4ff" text="#ffffff" border="#242c3d" background="#10141d"
        typography family="proportional" header-size=24.0 body-size=14.0
        spacing item-x=12.0 item-y=12.0 padding=16.0
        background-type "gradient"
        fill "#000000"
        secondary "#0a122c"
    }
    layout target="desktop" {
        top-panel id="dex-header" height=48.0 fill="#181f2eff" {
            column spacing=6.0 padding=8.0 {
                row align="center" spacing=16.0 {
                    image url="https://raw.githubusercontent.com/egui/egui/master/crates/egui/assets/ferris.svg" width=32.0 height=32.0 rounding=6.0
                    heading text="Media" color="text" size=18.0
                    spacer
                    label text="100%" color="accent" size=13.0
                }
                row align="center" spacing=10.0 {
                    device-switcher style="horizontal"
                    theme-switcher style="horizontal"
                }
            }
        }
        left-panel id="dex-sidebar" width=200.0 fill="#141a26ff" {
            column spacing=12.0 padding=14.0 {
                heading text="My Galaxy" size=14.0 color="accent"
                separator
                menu-bar id="category-nav" style="pills"
                spacer
                button label="Bixby" color="accent"
            }
        }
        bottom-panel id="dex-taskbar" height=40.0 fill="#181f2eff" {
            row align="center" spacing=16.0 {
                button label="Apps" color="accent"
                button label="Home" color="text"
                button label="Back" color="text"
                spacer
                label text="12:45 PM" color="secondary" size=13.0
            }
        }
        central-panel id="dex-content" fill="#00000000" {
            column spacing=16.0 padding=20.0 {
                catalog-view style="floating_cards" columns=3 rounding=20.0 border-width=1.0 {
                    animation effect="none" speed=1.0
                }
            }
        }
    }
    layout target="mobile" {
        top-panel id="one-ui-top" height=100.0 fill="#10141dff" {
            column spacing=10.0 padding=16.0 {
                row align="center" spacing=14.0 {
                    heading text="Media" color="text" size=28.0
                    spacer
                }
                row align="center" spacing=8.0 {
                    device-switcher style="compact"
                    theme-switcher style="horizontal"
                }
            }
        }
        bottom-panel id="one-ui-bottom" height=60.0 fill="#181f2eff" {
            row align="center" spacing=10.0 {
                menu-bar id="category-nav" style="pills"
            }
        }
        central-panel id="one-ui-feed" fill="#00000000" {
            column spacing=14.0 padding=14.0 {
                catalog-view style="floating_cards" columns=1 rounding=24.0 border-width=1.0 {
                    animation effect="none" speed=1.0
                }
            }
        }
    }
    layout target="tv" {
        top-panel id="tizen-header" height=80.0 fill="#181f2eff" {
            column spacing=10.0 padding=14.0 {
                row align="center" spacing=20.0 {
                    heading text="Media Hub" color="text" size=26.0
                    spacer
                    label text="100%" color="accent" size=16.0
                }
                row align="center" spacing=14.0 {
                    device-switcher style="horizontal"
                    theme-switcher style="horizontal"
                }
            }
        }
        bottom-panel id="tizen-footer" height=54.0 fill="#181f2eff" {
            row align="center" spacing=20.0 {
                label text="Select   Back   Home" color="accent" size=16.0
                spacer
                menu-bar id="category-nav" style="pills"
            }
        }
        central-panel id="tizen-plaza" fill="#00000000" {
            column spacing=20.0 padding=28.0 {
                catalog-view style="channel_grid" columns=4 rounding=20.0 border-width=2.0 {
                    animation effect="none" speed=1.0
                }
            }
        }
    }
}
