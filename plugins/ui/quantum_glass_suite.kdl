plugin id="quantum-glass-suite" name="Quantum Glass Aurora" mode="hotplug" {
    style {
        palette accent="#00e5ff" secondary="#ff007f" text="#f2f8ff" border="#00e5ff88" background="#040714"
        typography family="proportional" header-size=26.0 body-size=15.0
        spacing item-x=16.0 item-y=16.0 padding=22.0
        background-type "stars"
        fill "#00e5ff"
        secondary "#ff007f"
        speed 2.8
    }
    layout target="desktop" {
        top-panel id="glass-header" height=68.0 fill="#060b1ecc" {
            column spacing=8.0 padding=14.0 {
                row align="center" spacing=20.0 {
                    heading text="✨ QUANTUM // GLASS AURORA ✨" color="accent" size=22.0 effect="pulse" speed=1.5
                    spacer
                    device-switcher style="horizontal"
                }
            }
        }
        left-panel id="glass-side-nav" size=260.0 fill="#060b1ede" {
            column spacing=16.0 padding=20.0 {
                heading text="✨ AURORA NAV ✨" color="accent" size=20.0 effect="glow" speed=2.0
                label text="[ MEDIA CATEGORIES ]" color="secondary" size=12.0
                for-each source="{categories}" item="cat" {
                    button text="{cat.icon}   {cat.name}" action="SelectCategory:{cat.id}" size=16.0 rounding=14.0 effect="glow" speed=2.5
                    spacer size=8.0
                }
                spacer
                label text="[ SUITE SELECTOR ]" color="secondary" size=12.0
                theme-switcher style="vertical"
            }
        }
        central-panel id="glass-main" fill="#00000000" {
            column spacing=18.0 padding=24.0 {
                row align="center" spacing=12.0 {
                    label text="[ DYNAMIC STREAM ENGINE ACTIVE ]" color="secondary" size=14.0 effect="shimmer" speed=3.0
                }
                if-state source="{catalog_state}" equals="loading" {
                    row { label text="⏳ Loading Media Network..." color="accent" size=16.0 effect="pulse" speed=4.0 }
                }
                if-state source="{catalog_state}" equals="loaded" {
                    for-each source="{catalogs}" item="catalog" {
                        heading text="// {catalog.name}" color="accent" size=22.0 effect="glow" speed=1.5
                        spacer size=12.0
                        grid columns=3 min-cell-width=190.0 spacing-x=16.0 spacing-y=16.0 rounding=22.0 {
                            for-each source="{catalog.items}" item="item" {
                                box fill="#1a1a2ee0" rounding=22.0 padding=14.0 effect="glow" speed=2.5 border-width=1.5 {
                                    column spacing=8.0 {
                                        row {
                                            label text="►" color="accent" size=12.0 effect="pulse" speed=4.0
                                            label text="{item.title}" color="text" size=16.0
                                        }
                                        label text="{item.year} • {item.genres}" color="secondary" size=12.0
                                        button text="⚡ LINK: {item.id}" action="AddToLibrary:{item.id}" rounding=8.0 size=12.0 effect="pulse" speed=2.0
                                    }
                                }
                            }
                        }
                        spacer size=20.0
                    }
                }
            }
        }
    }
    layout target="mobile" {
        top-panel id="glass-mobile-header" height=64.0 fill="#060b1ecc" {
            column spacing=6.0 padding=12.0 {
                row align="center" spacing=14.0 {
                    heading text="✨ QUANTUM GLASS ✨" color="accent" size=18.0 effect="pulse" speed=1.5
                    spacer
                    device-switcher style="compact"
                    theme-switcher style="horizontal"
                }
            }
        }
        bottom-panel id="glass-mobile-footer" height=74.0 fill="#060b1ecc" {
            row align="center" spacing=16.0 {
                spacer
                for-each source="{categories}" item="cat" {
                    button text="{cat.icon}" action="SelectCategory:{cat.id}" size=22.0 rounding=24.0 effect="glow" speed=2.5
                    spacer size=12.0
                }
                spacer
            }
        }
        central-panel id="glass-mobile-feed" fill="#00000000" {
            column spacing=16.0 padding=16.0 {
                if-state source="{catalog_state}" equals="loading" {
                    row { label text="⏳ Loading..." color="accent" size=16.0 effect="pulse" speed=4.0 }
                }
                if-state source="{catalog_state}" equals="loaded" {
                    for-each source="{catalogs}" item="catalog" {
                        heading text="// {catalog.name}" color="accent" size=20.0 effect="glow" speed=1.5
                        grid columns=1 min-cell-width=200.0 spacing-y=16.0 {
                            for-each source="{catalog.items}" item="item" {
                                box fill="#1a1a2ee0" rounding=22.0 padding=14.0 effect="glow" speed=2.5 border-width=1.5 {
                                    column spacing=8.0 {
                                        row {
                                            label text="►" color="accent" size=12.0 effect="pulse" speed=4.0
                                            label text="{item.title}" color="text" size=16.0
                                        }
                                        label text="{item.year} • {item.genres}" color="secondary" size=12.0
                                        button text="⚡ LINK" action="AddToLibrary:{item.id}" rounding=8.0 size=12.0 effect="pulse" speed=2.0
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    layout target="tv" {
        top-panel id="glass-tv-header" height=86.0 fill="#060b1ecc" {
            column spacing=10.0 padding=18.0 {
                row align="center" spacing=24.0 {
                    heading text="✨ QUANTUM CINEMA AURORA ✨" color="accent" size=28.0 effect="pulse" speed=1.5
                    spacer
                    device-switcher style="horizontal"
                    theme-switcher style="horizontal"
                }
            }
        }
        bottom-panel id="glass-tv-footer" height=80.0 fill="#060b1ecc" {
            row align="center" spacing=28.0 {
                spacer
                for-each source="{categories}" item="cat" {
                    button text="• {cat.name} •" action="SelectCategory:{cat.id}" size=28.0 rounding=24.0 effect="glow" speed=2.5
                    spacer size=24.0
                }
                spacer
            }
        }
        central-panel id="glass-tv-grid" fill="#00000000" {
            column spacing=24.0 padding=30.0 {
                if-state source="{catalog_state}" equals="loading" {
                    row { label text="⏳ Loading TV Grid..." color="accent" size=24.0 effect="pulse" speed=4.0 }
                }
                if-state source="{catalog_state}" equals="loaded" {
                    for-each source="{catalogs}" item="catalog" {
                        heading text="// {catalog.name}" color="accent" size=26.0 effect="glow" speed=1.5
                        grid columns=4 min-cell-width=240.0 spacing-x=24.0 spacing-y=24.0 rounding=24.0 {
                            for-each source="{catalog.items}" item="item" {
                                box fill="#1a1a2ee0" rounding=24.0 padding=18.0 effect="glow" speed=2.5 border-width=2.0 {
                                    column spacing=12.0 {
                                        row {
                                            label text="►" color="accent" size=16.0 effect="pulse" speed=4.0
                                            label text="{item.title}" color="text" size=20.0
                                        }
                                        label text="{item.year} • {item.genres}" color="secondary" size=16.0
                                        button text="⚡ LINK" action="AddToLibrary:{item.id}" rounding=12.0 size=16.0 effect="pulse" speed=2.0
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
